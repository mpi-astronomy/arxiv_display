% Use a temporary dictionary
50 dict begin
%START GAG_PS_HEADER
/m {stroke moveto} bind def
/l {lineto} bind def
/s {stroke} bind def
/S {currentpoint stroke moveto} bind def
/NP {newpath} bind def
/CPF {closepath fill} bind def
/PenSelect { GAG_pensize mod 3 mul GAG_Pen exch 3 getinterval
 aload pop setrgbcolor } bind def
/PS { grestore GAG_pensize mod 3 mul GAG_Pen exch 3 getinterval
 aload pop setrgbcolor gsave} bind def
/FillSelect { GAG_fillsize mod 3 mul GAG_Fill exch 3 getinterval
 aload pop setrgbcolor } bind def
/FS { grestore GAG_fillsize mod 3 mul GAG_Fill exch 3 getinterval
 aload pop setrgbcolor gsave } bind def
/WS { grestore setlinewidth gsave} bind def
/DS { grestore 0 setdash 1 setlinecap 1 setlinejoin gsave } bind def
% For oldies that do not know colorimage operator
/colorimage where   % is known?
{pop}               % Yes: pop off the dictionary returned
  {                 % no:  define colorimage
  /picstr 32 string def    % implies that image was written as 96Z2.2 !
  /RGBpicstr 96 string def % idem...
  /CopyStr {currentfile picstr readhexstring pop} def
  /CopyRGBStr {currentfile RGBpicstr readhexstring pop} def
  /colorimage
  {                  % def
   pop pop pop       % remove '{readhex...} false 3' operands
   { CopyRGBStr pop
     0 1 31
    { picstr exch
      dup
      RGBpicstr exch 3 mul 3 getinterval {cvr 255 div} forall 0.11 mul exch
      0.59 mul add exch 0.3 mul add 255 mul cvi put
    } for
  picstr } image
  } bind def
 } ifelse          % end of 'false' case
%End GAG_PS_HEADER
